<%- include('../layout/header') %>

<h1>Sản phẩm nhà thuốc</h1>

<form class="filter-bar" method="get" action="/">
  <div class="search-box">
    <input type="text" name="q" id="search-input" value="<%= q %>" placeholder="Tìm theo tên sản phẩm…"
           autocomplete="off">
    <div id="suggest-dropdown" class="suggest-dropdown" hidden></div>
  </div>
  <select name="sort">
    <option value="name_asc" <%= sort === 'name_asc' ? 'selected' : '' %>>Tên A → Z</option>
    <option value="name_desc" <%= sort === 'name_desc' ? 'selected' : '' %>>Tên Z → A</option>
    <option value="price_asc" <%= sort === 'price_asc' ? 'selected' : '' %>>Giá tăng dần</option>
    <option value="price_desc" <%= sort === 'price_desc' ? 'selected' : '' %>>Giá giảm dần</option>
  </select>
  <button type="submit" class="btn btn-primary">Tìm</button>
  <% if (q || sort !== 'name_asc') { %>
    <a href="/" class="btn">Xóa lọc</a>
  <% } %>
</form>

<% if (products.length === 0) { %>
  <div class="empty-state">
    <p>Không tìm thấy sản phẩm nào<% if (q) { %> khớp với "<%= q %>"<% } %>.</p>
    <p><a href="/">← Xem tất cả sản phẩm</a></p>
  </div>
<% } else { %>
  <div class="product-grid">
    <% for (const p of products) { %>
      <div class="product-card">
        <a href="/products/<%= p.id %>" class="product-emoji-link">
          <div class="product-emoji"><%= p.image_emoji || '💊' %></div>
        </a>
        <h3><a href="/products/<%= p.id %>"><%= p.name %></a></h3>
        <p class="muted"><%= p.description %></p>
        <p class="price"><%= formatVND(p.price) %></p>
        <p class="stock <%= p.stock === 0 ? 'stock-out' : (p.stock < LOW_STOCK_THRESHOLD ? 'stock-low' : '') %>">
          <% if (p.stock === 0) { %>Hết hàng<% } else { %>Còn <%= p.stock %> sản phẩm<% } %>
        </p>
        <p class="sold-count">Đã bán: <%= p.sold_count %></p>
        <% if (currentUser && currentUser.role === 'customer') { %>
          <% if (p.stock > 0) { %>
            <form action="/cart/add" method="post" class="add-to-cart">
              <input type="hidden" name="product_id" value="<%= p.id %>">
              <input type="number" name="quantity" value="1" min="1" max="<%= p.stock %>">
              <button type="submit" class="btn btn-primary">Thêm vào giỏ</button>
            </form>
          <% } else { %>
            <button type="button" class="btn add-to-cart" disabled>Hết hàng</button>
          <% } %>
        <% } else if (!currentUser) { %>
          <p class="muted small"><a href="/login">Đăng nhập</a> để mua hàng</p>
        <% } %>
      </div>
    <% } %>
  </div>
<% } %>

<script>
  // Gợi ý tìm kiếm (autocomplete): debounce ~300ms, tối thiểu 2 ký tự, fetch JSON, dropdown
  (function () {
    const input = document.getElementById('search-input');
    const dropdown = document.getElementById('suggest-dropdown');
    if (!input || !dropdown) return;
    let timer = null;

    const formatVND = (n) => Number(n).toLocaleString('vi-VN') + ' ₫';

    function hide() { dropdown.hidden = true; dropdown.innerHTML = ''; }

    async function fetchSuggest(q) {
      try {
        const res = await fetch('/api/products/suggest?q=' + encodeURIComponent(q));
        if (!res.ok) return;
        const items = await res.json();
        if (!items.length) { hide(); return; }
        dropdown.innerHTML = items
          .map(
            (p) =>
              '<a class="suggest-item" href="/products/' + p.id + '">' +
              '<span class="suggest-emoji">' + (p.image_emoji || '💊') + '</span>' +
              '<span class="suggest-name"></span>' +
              '<span class="suggest-price">' + formatVND(p.price) + '</span>' +
              '</a>'
          )
          .join('');
        // Gán tên qua textContent để tránh XSS
        const names = dropdown.querySelectorAll('.suggest-name');
        items.forEach((p, i) => { names[i].textContent = p.name; });
        dropdown.hidden = false;
      } catch (e) {
        hide();
      }
    }

    input.addEventListener('input', function () {
      const q = input.value.trim();
      clearTimeout(timer);
      if (q.length < 2) { hide(); return; }
      timer = setTimeout(() => fetchSuggest(q), 300);
    });

    // Ẩn dropdown khi click ra ngoài (dùng mousedown để không chặn click vào gợi ý)
    document.addEventListener('mousedown', function (e) {
      if (!dropdown.contains(e.target) && e.target !== input) hide();
    });
    input.addEventListener('blur', function () { setTimeout(hide, 150); });
  })();
</script>

<%- include('../layout/footer') %>
